# Port the desktop service listens on (frontend connects here).
DESKTOP_PORT=3001

# Comma-separated list of origins allowed to call the service.
# In development this is the voice app origin.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Permission policy: "allow" (run silently, log everything — default),
# "prompt" (ask the user per action), or "deny" (block sensitive actions).
PERMISSION_MODE=allow

# Root directories the file/search tools are permitted to read or open.
# Comma-separated. Defaults to the current user's common folders.
# Leave blank to auto-derive the standard user folders.
ALLOWED_ROOTS=
