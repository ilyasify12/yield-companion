{
  "name": "yield-companion",
  "private": true,
  "version": "1.2.0",
  "description": "YIELD COMPANION — Voice AI with Desktop PC Control",
  "author": "YIELD",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:frontend && npm run build:server",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --minify --outfile=server-dist/server.cjs",
    "build:desktop": "cd desktop && tsc -p tsconfig.json",
    "build:electron": "npm run build && npm run build:desktop",
    "start": "node server-dist/server.cjs",
    "electron:dev": "npx electron electron/main.cjs",
    "electron:start": "npm run build:electron && npx electron electron/main.cjs",
    "dist": "npm run build:electron && npx electron-builder --win",
    "dist:dir": "npm run build:electron && npx electron-builder --win --dir",
    "clean": "rm -rf dist server-dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "openai": "^6.45.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.yield-companion.app",
    "productName": "YIELD COMPANION",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server-dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "desktop/dist",
        "to": "desktop/dist",
        "filter": ["**/*"]
      },
      {
        "from": "desktop/node_modules",
        "to": "desktop/node_modules",
        "filter": ["**/*", "!typescript/**", "!@esbuild/**", "!@types/**", "!rimraf/**", "!tsx/**"]
      },
      {
        "from": "desktop/package.json",
        "to": "desktop/package.json"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "asarUnpack": [
      "dist/**",
      "server-dist/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "YIELD-COMPANION-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YIELD COMPANION",
      "uninstallDisplayName": "YIELD COMPANION",
      "runAfterFinish": true
    }
  }
}
